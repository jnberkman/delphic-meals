# PostgreSQL (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgres://user:password@localhost:5432/delphic_meals

# Server
PORT=3000
NODE_ENV=development

# CORS — allowed frontend origin
FRONTEND_URL=https://rmeek-robot.github.io

# Google Sheets sync (service account)
GOOGLE_SERVICE_ACCOUNT_KEY=   # base64-encoded service account JSON key
GOOGLE_SPREADSHEET_ID=        # spreadsheet ID from the Google Sheets URL

# Email (SMTP)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=                    # API key
EMAIL_FROM=Delphic Club <meals@delphicclub.com>

# Backend URL (for claim links in emails)
BACKEND_URL=http://localhost:3000
